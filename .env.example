# Your Signal phone number in E.164 format (the account this gateway will link to).
SIGNAL_NUMBER=+15551234567

# Shared secret for the /notify endpoint.
# Generate with: openssl rand -hex 16
NOTIFY_TOKEN=replace-me

# Shared secret for the /register and /routes endpoints. Use a DIFFERENT value.
# Generate with: openssl rand -hex 16
ROUTER_TOKEN=replace-me-too
